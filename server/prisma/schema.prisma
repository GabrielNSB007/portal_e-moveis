generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CLIENTE
  VENDEDOR
}

enum OfferStatus {
  ATIVA
  PAUSADA
  VENDIDA
  EXPIRADA
}

enum PropertyType {
  APARTAMENTO
  CASA
  STUDIO
  COBERTURA
  TERRENO
}

enum MatchStatus {
  PENDENTE
  VISUALIZADO
  PROPOSTA_ENVIADA
  RECUSADO
  FEITO
}

enum ProposalStatus {
  PENDENTE
  ACEITA
  RECUSADA
  CANCELADA
}

enum MediaType {
  FOTO
  VIDEO
}

enum Amenity {
  PISCINA
  ACADEMIA
  CHURRASQUEIRA
  ELEVADOR
  PORTARIA
  MOBILIADO
  PET_FRIENDLY
  VARANDA
  AREA_SERVICO
}

enum DocumentStatus {
  PENDING
  REVIEW
  VERIFIED
  REJECTED
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      UserRole @default(CLIENTE)
  phone     String?

  offers        Offer[]
  preferences   Preference[]
  proposalsSent Proposal[] @relation("BuyerProposals")
  profile       UserProfile?
  passwordRecoveryCodes PasswordRecoveryCode[]
  savedOffers   SavedOffer[]
  notifications Notification[]
  views     OfferView[]
  visits    OfferVisit[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserProfile {
  id               String         @id @default(uuid())
  userId           String         @unique
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  avatarUrl        String?
  income           Decimal?       @db.Decimal(12, 2)
  downPayment      Decimal?       @db.Decimal(12, 2)
  needsFinancing   Boolean?
  purchaseType     String?
  documentId       String?
  documentStatus   DocumentStatus @default(PENDING)
  documentSubmittedAt DateTime?
  verifiedAt       DateTime?

  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model PasswordRecoveryCode {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash  String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
}

model Offer {
  id           String       @id @default(uuid())
  title        String
  description  String?
  price        Decimal      @db.Decimal(12, 2)
  areaM2       Float
  bedrooms     Int
  bathrooms    Int
  parkingSpots Int
  propertyType PropertyType
  status       OfferStatus  @default(ATIVA)

  neighborhood String
  city         String
  state        String
  address      String?

  amenities Amenity[]

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  media     OfferMedia[]
  matches   Match[]
  proposals Proposal[]
  savedBy   SavedOffer[]
  notifications Notification[]
  views     OfferView[]
  visits    OfferVisit[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([neighborhood])
  @@index([city, state])
  @@index([price])
  @@index([bedrooms, bathrooms, parkingSpots])
}

model OfferMedia {
  id      String    @id @default(uuid())
  url     String
  type    MediaType

  offerId String
  offer   Offer     @relation(fields: [offerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model Preference {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  title String?

  minPrice Decimal? @db.Decimal(12, 2)
  maxPrice Decimal? @db.Decimal(12, 2)

  minAreaM2 Float?
  maxAreaM2 Float?

  minBedrooms     Int?
  minBathrooms    Int?
  minParkingSpots Int?

  propertyTypes   PropertyType[]
  neighborhoods   String[]
  city            String
  state           String
  desiredAmenities Amenity[]

  isActive Boolean @default(true)

  matches Match[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([city, state])
}

model Match {
  id String @id @default(uuid())

  offerId String
  offer   Offer  @relation(fields: [offerId], references: [id], onDelete: Cascade)

  preferenceId String
  preference   Preference @relation(fields: [preferenceId], references: [id], onDelete: Cascade)

  score  Float
  status MatchStatus @default(PENDENTE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([offerId, preferenceId])
  @@index([score])
}



model OfferView {
  id String @id @default(uuid())

  offerId String
  offer   Offer  @relation(fields: [offerId], references: [id], onDelete: Cascade)

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([offerId, createdAt])
  @@index([userId])
}

model OfferVisit {
  id String @id @default(uuid())

  offerId String
  offer   Offer  @relation(fields: [offerId], references: [id], onDelete: Cascade)

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  scheduledFor DateTime?
  status       String @default("REQUESTED")
  createdAt    DateTime @default(now())

  @@index([offerId, createdAt])
  @@index([userId])
}

model SavedOffer {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  offerId String
  offer   Offer  @relation(fields: [offerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, offerId])
  @@index([userId])
  @@index([offerId])
}

model Notification {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  offerId String?
  offer   Offer? @relation(fields: [offerId], references: [id], onDelete: SetNull)

  type        String
  title       String
  description String
  read        Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, read])
  @@index([offerId])
}

model Proposal {
  id String @id @default(uuid())

  offerId String
  offer   Offer  @relation(fields: [offerId], references: [id], onDelete: Cascade)

  buyerId String
  buyer   User   @relation("BuyerProposals", fields: [buyerId], references: [id], onDelete: Cascade)

  message String?
  value   Decimal? @db.Decimal(12, 2)
  status  ProposalStatus @default(PENDENTE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([offerId, buyerId])
  @@index([buyerId])
  @@index([offerId])
  @@index([status])
}